{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SG Immigration Strategist Analyze Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "readiness_score",
    "eligibility_signal",
    "system_status",
    "scoring_breakdown",
    "official_takeaways",
    "community_takeaways",
    "top_strengths",
    "top_risks",
    "missing_documents",
    "recommended_actions",
    "confidence_notes",
    "data_sources_used",
    "error_note"
  ],
  "properties": {
    "readiness_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "eligibility_signal": {
      "type": "string",
      "enum": ["low", "moderate", "strong"]
    },
    "system_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_mode",
        "retrieval_mode",
        "used_fallback_response",
        "used_live_openai",
        "used_live_retrieval"
      ],
      "properties": {
        "analysis_mode": {
          "type": "string",
          "enum": ["demo_fallback", "openai_only", "retrieval_augmented"]
        },
        "retrieval_mode": {
          "type": "string",
          "enum": ["unavailable", "openai_only", "retrieval_augmented"]
        },
        "used_fallback_response": { "type": "boolean" },
        "used_live_openai": { "type": "boolean" },
        "used_live_retrieval": { "type": "boolean" }
      }
    },
    "scoring_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rubric_name",
        "preliminary_score",
        "final_score",
        "score_adjustment",
        "source_quality",
        "band_guidance",
        "dimensions"
      ],
      "properties": {
        "rubric_name": { "type": "string" },
        "preliminary_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "final_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "score_adjustment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["direction", "delta", "driver", "reason"],
          "properties": {
            "direction": {
              "type": "string",
              "enum": ["up", "down", "none"]
            },
            "delta": { "type": "integer" },
            "driver": {
              "type": "string",
              "enum": ["official_evidence", "uncertainty", "none"]
            },
            "reason": { "type": "string" }
          }
        },
        "source_quality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["official", "community"],
          "properties": {
            "official": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "label", "reason"],
              "properties": {
                "level": {
                  "type": "string",
                  "enum": ["strong", "mixed", "thin", "missing"]
                },
                "label": { "type": "string" },
                "reason": { "type": "string" }
              }
            },
            "community": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "label", "reason"],
              "properties": {
                "level": {
                  "type": "string",
                  "enum": ["strong", "mixed", "thin", "missing"]
                },
                "label": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          }
        },
        "band_guidance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "moderate", "strong"],
          "properties": {
            "low": { "type": "string" },
            "moderate": { "type": "string" },
            "strong": { "type": "string" }
          }
        },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "label", "score", "max_score", "reason"],
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "score": { "type": "integer" },
              "max_score": { "type": "integer" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "official_takeaways": {
      "type": "array",
      "items": { "type": "string" }
    },
    "community_takeaways": {
      "type": "array",
      "items": { "type": "string" }
    },
    "top_strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "top_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_documents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data_sources_used": {
      "type": "object",
      "additionalProperties": false,
      "required": ["official_source", "community_source"],
      "properties": {
        "official_source": { "type": "string" },
        "community_source": { "type": "string" }
      }
    },
    "error_note": {
      "type": ["string", "null"]
    }
  }
}
